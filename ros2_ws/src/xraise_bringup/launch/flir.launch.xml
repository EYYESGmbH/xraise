<launch>
  <!-- This launchfile should bring up a node that broadcasts a ros image
       transport on /videofile/image_raw -->
  
  <node name="gscam_driver_v4l" pkg="gscam" exec="gscam_node" output="screen">
    <param name="camera_name" value="default"/>
    <param name="camera_info_url" value="package://gscam/examples/uncalibrated_parameters.ini"/>
    <!--param name="gscam_config" value="filesrc location=$(arg FILENAME) ! decodebin ! ffmpegcolorspace"/-->
    <!--param name="gscam_config" value="rtspsrc location=rtsp://192.168.0.90/axis-media/media.amp latency=50 ! queue ! rtph264depay ! h264parse ! nvv4l2decoder ! nvvidconv ! video/x-raw(memory:NVMM),format=(string)RGBA ! videoconvert "/-->
	<param name="gscam_config" value="rtspsrc location=rtsp://192.168.0.96/avc?ch0 latency=50 ! queue ! rtph264depay ! h264parse ! nvv4l2decoder ! nvvidconv ! videoconvert "/>
    <param name="frame_id" value="flir"/>
    <param name="sync_sink" value="true"/>
    <remap from="camera/image_raw" to="flir/image_raw" />
    <remap from="camera/image_raw/compressed" to="flir/image_raw/compressed" />
    <remap from="camera/image_raw/compressedDepth" to="flir/image_raw/compressedDepth" />
  </node>

  <node name="videofile_transform" pkg="tf2_ros" exec="static_transform_publisher" args="0 0 0 0 0 0 world flir"/>
</launch>
